// ===========================
// APP STATE
// ===========================
let selectedMode = 'all';
let selectedCount = 10;
let questions = [];
let currentIdx = 0;
let answers = [];
let timerInterval = null;
let timeLeft = 0;
let sessionResults = null;

// ===========================
// HOME LOGIC
// ===========================
function selectMode(m) {
  selectedMode = m;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('selected'));
  document.getElementById('mode-' + m).classList.add('selected');
}

function selectCount(n) {
  selectedCount = n;
  document.querySelectorAll('.count-chip').forEach(c => c.classList.remove('selected'));
  document.getElementById('cnt-' + n).classList.add('selected');
}

function buildQuestions() {
  let pool = [];
  if (selectedMode === 'all' || selectedMode === 'closed') {
    pool.push(...CLOSED_Q.map(q => ({ ...q, type: 'closed' })));
  }
  if (selectedMode === 'all' || selectedMode === 'match') {
    pool.push(...MATCH_Q.map(q => ({ ...q, type: 'match' })));
  }
  if (selectedMode === 'all' || selectedMode === 'open') {
    pool.push(...OPEN_Q.map(q => ({ ...q, type: 'open' })));
  }
  // Shuffle
  for (let i = pool.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [pool[i], pool[j]] = [pool[j], pool[i]];
  }
  return pool.slice(0, Math.min(selectedCount, pool.length));
}

function startQuiz() {
  questions = buildQuestions();
  answers = new Array(questions.length).fill(null);
  currentIdx = 0;
  showScreen('quiz');
  renderQuestion();
}

function goHome() { showScreen('home'); renderHistory(); }
function restartQuiz() { startQuiz(); }
function backToResult() { showScreen('result'); }

function confirmExit() {
  if (confirm('Тестро ?атъ кунед?')) {
    clearTimer();
    goHome();
  }
}

// ===========================
// QUIZ RENDER
// ===========================
function renderQuestion() {
  const q = questions[currentIdx];
  const total = questions.length;

  // Header
  document.getElementById('q-num').textContent = `${currentIdx + 1} / ${total}`;
  document.getElementById('progress-fill').style.width = `${((currentIdx + 1) / total) * 100}%`;

  // Badge
  const badge = document.getElementById('q-type-badge');
  if (q.type === 'closed') {
    badge.textContent = 'П?шида • 3 хол';
    badge.className = 'quiz-type-badge badge-closed';
  } else if (q.type === 'match') {
    badge.textContent = 'Мувофи?ат • 8 хол';
    badge.className = 'quiz-type-badge badge-match';
  } else {
    badge.textContent = 'Кушода • 4 хол';
    badge.className = 'quiz-type-badge badge-open';
  }

  // Timer
  startTimer(q.type === 'closed' ? 45 : q.type === 'match' ? 90 : 60);

  // Next btn reset
  const nb = document.getElementById('next-btn');
  nb.className = 'next-btn skip';
  nb.textContent = 'Гузаштан ?';
  nb.disabled = false;

  // Render body
  const body = document.getElementById('quiz-body');
  if (q.type === 'closed') renderClosed(q, body);
  else if (q.type === 'match') renderMatch(q, body);
  else renderOpen(q, body);

  // Scroll top
  body.scrollTop = 0;
}

function renderClosed(q, body) {
  const letters = ['A', 'B', 'C', 'D'];
  body.innerHTML = `
    <div class="question-points">Намуди п?шида <span class="pts-badge">+3 хол</span></div>
    <div class="question-text">${q.q}</div>
    <div class="options-list">
      ${q.opts.map((opt, i) => `
        <button class="option-btn" onclick="selectOption(${i})" id="opt-${i}">
          <div class="option-letter">${letters[i]}</div>
          <div>${opt}</div>
        </button>
      `).join('')}
    </div>
  `;
}

function selectOption(i) {
  // Already answered?
  if (document.getElementById('opt-' + i).disabled) return;
  answers[currentIdx] = { type: 'closed', selected: i };
  document.querySelectorAll('.option-btn').forEach((b, idx) => {
    b.classList.remove('selected');
  });
  document.getElementById('opt-' + i).classList.add('selected');
  const nb = document.getElementById('next-btn');
  nb.className = 'next-btn ready';
  nb.textContent = '?авоб додан ?';
}

function renderMatch(q, body) {
  const nums = q.rights.map((_, i) => i + 1);
  body.innerHTML = `
    <div class="question-points">Намуди мувофи?ат <span class="pts-badge">+8 хол</span></div>
    <div class="question-text">${q.q}</div>
    <div class="match-label">Тарафи чап — интихоб кунед:</div>
    <div class="match-left-list">
      ${q.lefts.map((l, i) => `
        <div class="match-item-left">
          <div class="match-letter">${String.fromCharCode(65 + i)}</div>
          <div style="flex:1;font-size:13px">${l}</div>
          <select class="match-select" id="ms-${i}" onchange="matchChanged(${i})">
            <option value="">—</option>
            ${q.rights.map((_, ri) => `<option value="${ri + 1}">${ri + 1}</option>`).join('')}
          </select>
        </div>
      `).join('')}
    </div>
    <div class="match-label" style="margin-top:8px">Тарафи рост:</div>
    <div class="match-right-list">
      ${q.rights.map((r, i) => `
        <div class="match-right-item">
          <div class="match-num">${i + 1}</div>
          <div>${r}</div>
        </div>
      `).join('')}
    </div>
  `;
}

function matchChanged(i) {
  const sel = document.getElementById('ms-' + i);
  sel.className = sel.value ? 'match-select filled' : 'match-select';
  checkMatchComplete();
}

function checkMatchComplete() {
  const q = questions[currentIdx];
  const vals = q.lefts.map((_, i) => {
    const s = document.getElementById('ms-' + i);
    return s ? parseInt(s.value) || 0 : 0;
  });
  const allFilled = vals.every(v => v > 0);
  if (allFilled) {
    answers[currentIdx] = { type: 'match', selected: vals };
    const nb = document.getElementById('next-btn');
    nb.className = 'next-btn ready';
    nb.textContent = '?авоб додан ?';
  }
}

function renderOpen(q, body) {
  body.innerHTML = `
    <div class="question-points">Намуди кушода <span class="pts-badge">+4 хол</span></div>
    <div class="question-text">${q.q}</div>
    <input type="text" class="open-input" id="open-input" placeholder="?авобро нависед..."
      oninput="openInputChanged()" onkeydown="if(event.key==='Enter') nextQuestion()">
    <div class="open-hint">Ададро бе во?ид нависед (масалан: 4,48)</div>
    <div class="open-answer-reveal" id="open-reveal"></div>
  `;
  setTimeout(() => {
    const inp = document.getElementById('open-input');
    if (inp) inp.focus();
  }, 300);
}

function openInputChanged() {
  const val = document.getElementById('open-input')?.value?.trim();
  const nb = document.getElementById('next-btn');
  if (val && val.length > 0) {
    answers[currentIdx] = { type: 'open', selected: val };
    nb.className = 'next-btn ready';
    nb.textContent = '?авоб додан ?';
  } else {
    answers[currentIdx] = null;
    nb.className = 'next-btn skip';
    nb.textContent = 'Гузаштан ?';
  }
}

// ===========================
// TIMER
// ===========================
function startTimer(seconds) {
  clearTimer();
  timeLeft = seconds;
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerDisplay();
    if (timeLeft <= 0) {
      clearTimer();
      autoSkip();
    }
  }, 1000);
}

function updateTimerDisplay() {
  const el = document.getElementById('timer-display');
  const m = Math.floor(timeLeft / 60);
  const s = timeLeft % 60;
  el.textContent = m > 0 ? `${m}:${s.toString().padStart(2, '0')}` : `${timeLeft}s`;
  el.className = 'timer-display' + (timeLeft <= 10 ? ' danger' : timeLeft <= 20 ? ' warning' : '');
}

function clearTimer() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
}

function autoSkip() {
  // Show correct answer briefly then move on
  const q = questions[currentIdx];
  if (!answers[currentIdx]) answers[currentIdx] = { type: q.type, selected: null, timedOut: true };
  showAnswerFeedback(true);
  setTimeout(() => nextQuestion(true), 1500);
}

// ===========================
// NEXT / ANSWER
// ===========================
function nextQuestion(auto = false) {
  clearTimer();
  const q = questions[currentIdx];
  const ans = answers[currentIdx];

  if (!auto && !ans) {
    // Skip
    answers[currentIdx] = { type: q.type, selected: null, skipped: true };
  }

  if (!auto) {
    showAnswerFeedback(false);
    setTimeout(proceed, ans ? 800 : 0);
  } else {
    proceed();
  }
}

function showAnswerFeedback(auto) {
  const q = questions[currentIdx];
  const ans = answers[currentIdx];
  if (!ans || ans.selected === null) return;

  if (q.type === 'closed') {
    const isCorrect = ans.selected === q.ans;
    document.querySelectorAll('.option-btn').forEach((btn, i) => {
      btn.disabled = true;
      if (i === q.ans) btn.classList.add('correct');
      else if (i === ans.selected && !isCorrect) btn.classList.add('wrong');
    });
  } else if (q.type === 'match') {
    q.lefts.forEach((_, i) => {
      const sel = document.getElementById('ms-' + i);
      if (!sel) return;
      sel.disabled = true;
      const correct = q.ans[i] === parseInt(sel.value);
      sel.className = correct ? 'match-select correct-sel' : 'match-select wrong-sel';
    });
  } else if (q.type === 'open') {
    const reveal = document.getElementById('open-reveal');
    if (reveal) {
      reveal.textContent = `? ?авоби дуруст: ${q.ans}`;
      reveal.classList.add('show');
    }
    const inp = document.getElementById('open-input');
    if (inp) inp.disabled = true;
  }
}

function proceed() {
  if (currentIdx < questions.length - 1) {
    currentIdx++;
    renderQuestion();
  } else {
    finishQuiz();
  }
}

// ===========================
// FINISH & RESULTS
// ===========================
function calcScore() {
  let earned = 0, total = 0, correct = 0, wrong = 0, skip = 0;
  questions.forEach((q, i) => {
    const ans = answers[i];
    if (q.type === 'closed') {
      total += 3;
      if (!ans || ans.selected === null) { skip++; }
      else if (ans.selected === q.ans) { earned += 3; correct++; }
      else { wrong++; }
    } else if (q.type === 'match') {
      total += 8;
      if (!ans || ans.selected === null) { skip++; }
      else {
        let pts = 0;
        q.ans.forEach((a, i2) => {
          if (ans.selected[i2] === a) pts += 2;
        });
        earned += pts;
        if (pts === 8) correct++;
        else if (pts === 0) wrong++;
        else { correct++; } // partial
      }
    } else {
      total += 4;
      if (!ans || ans.selected === null) { skip++; }
      else {
        const userAns = String(ans.selected).trim().replace(',', '.');
        const correctAns = String(q.ans).trim().replace(',', '.');
        if (userAns === correctAns) { earned += 4; correct++; }
        else { wrong++; }
      }
    }
  });
  const percent = Math.round((earned / total) * 100);
  const grade = calcGrade(percent);
  return { earned, total, percent, correct, wrong, skip, grade };
}

function calcGrade(percent) {
  if (percent >= 91) return 10;
  if (percent >= 81) return 9;
  if (percent >= 71) return 8;
  if (percent >= 61) return 7;
  if (percent >= 51) return 6;
  if (percent >= 41) return 5;
  if (percent >= 31) return 4;
  if (percent >= 21) return 3;
  if (percent >= 11) return 2;
  return 1;
}

function finishQuiz() {
  clearTimer();
  sessionResults = calcScore();
  saveHistory(sessionResults);
  showResultScreen(sessionResults);
  if (sessionResults.grade >= 8) spawnConfetti();
}

function showResultScreen(r) {
  showScreen('result');
  const gradeEl = document.getElementById('result-grade-num');
  const emoji = r.grade >= 9 ? '??' : r.grade >= 7 ? '??' : r.grade >= 5 ? '??' : '??';
  const msg = r.grade >= 9 ? 'Аъло! Баракалло!' : r.grade >= 7 ? 'Хуб! Давом ди?ед!' : r.grade >= 5 ? '?аноатбахш' : 'Бояд такрор кунед';
  const colors = { 10: '#f59e0b', 9: '#f59e0b', 8: '#10b981', 7: '#10b981', 6: '#3b82f6', 5: '#3b82f6', 4: '#ef4444', 3: '#ef4444', 2: '#ef4444', 1: '#ef4444' };

  document.getElementById('result-emoji').textContent = emoji;
  gradeEl.textContent = r.grade;
  gradeEl.style.color = colors[r.grade];
  document.getElementById('result-msg').textContent = msg;
  document.getElementById('r-points').textContent = r.earned;
  document.getElementById('r-total').textContent = r.total;
  document.getElementById('r-percent').textContent = r.percent + '%';
  document.getElementById('r-correct').textContent = r.correct + ' ?';
  document.getElementById('r-wrong').textContent = r.wrong + ' ?';
  document.getElementById('r-skip').textContent = r.skip;
}

// ===========================
// REVIEW
// ===========================
function showReview() {
  showScreen('review');
  const body = document.getElementById('review-body');
  body.innerHTML = '';
  questions.forEach((q, i) => {
    const ans = answers[i];
    let cls = 'r-skip', icon = '?', yourAns = '—', corrAns = '';
    if (ans && ans.selected !== null) {
      if (q.type === 'closed') {
        const correct = ans.selected === q.ans;
        cls = correct ? 'r-correct' : 'r-wrong';
        icon = correct ? '?' : '?';
        yourAns = q.opts[ans.selected] || '—';
        corrAns = q.opts[q.ans];
      } else if (q.type === 'match') {
        const allCorrect = q.ans.every((a, i2) => ans.selected[i2] === a);
        cls = allCorrect ? 'r-correct' : 'r-wrong';
        icon = allCorrect ? '?' : '?';
        yourAns = ans.selected.join('-');
        corrAns = q.ans.join('-');
      } else {
        const correct = String(ans.selected).trim().replace(',', '.') === String(q.ans).trim().replace(',', '.');
        cls = correct ? 'r-correct' : 'r-wrong';
        icon = correct ? '?' : '?';
        yourAns = ans.selected;
        corrAns = q.ans;
      }
    }
    const div = document.createElement('div');
    div.className = `review-item ${cls}`;
    div.innerHTML = `
      <div class="review-qnum">Савол ${i + 1} ${icon}</div>
      <div class="review-qtext">${q.q.substring(0, 100)}${q.q.length > 100 ? '...' : ''}</div>
      <div class="review-answer-row">
        <span class="review-your">Шумо: ${yourAns}</span>
        <span class="review-correct">Дуруст: ${corrAns || yourAns}</span>
      </div>
    `;
    body.appendChild(div);
  });
}

// ===========================
// HISTORY
// ===========================
function saveHistory(r) {
  const hist = JSON.parse(localStorage.getItem('kimyo_hist') || '[]');
  const modeNames = { all: '?ама', closed: 'П?шида', match: 'Мувофи?ат', open: 'Кушода' };
  hist.unshift({
    mode: modeNames[selectedMode],
    count: questions.length,
    grade: r.grade,
    percent: r.percent,
    date: new Date().toLocaleDateString('tg-TJ')
  });
  localStorage.setItem('kimyo_hist', JSON.stringify(hist.slice(0, 10)));
}

function renderHistory() {
  const hist = JSON.parse(localStorage.getItem('kimyo_hist') || '[]');
  const list = document.getElementById('history-list');
  const section = document.getElementById('history-section');
  if (!hist.length) { section.style.display = 'none'; return; }
  section.style.display = 'block';
  list.innerHTML = hist.slice(0, 4).map(h => {
    const cls = h.grade >= 8 ? 's10' : h.grade >= 6 ? 's7' : h.grade >= 4 ? 's5' : 's3';
    return `
      <div class="history-card">
        <div class="hist-left">
          <div class="hist-mode">${h.mode} • ${h.count} савол • ${h.percent}%</div>
          <div class="hist-date">${h.date}</div>
        </div>
        <div class="hist-score ${cls}">${h.grade}</div>
      </div>
    `;
  }).join('');
}

// ===========================
// CONFETTI
// ===========================
function spawnConfetti() {
  const colors = ['#3b82f6', '#06b6d4', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6'];
  for (let i = 0; i < 40; i++) {
    setTimeout(() => {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.left = Math.random() * 100 + 'vw';
      el.style.top = '-10px';
      el.style.background = colors[Math.floor(Math.random() * colors.length)];
      el.style.animationDelay = (Math.random() * 0.5) + 's';
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 3000);
    }, i * 40);
  }
}

// ===========================
// SCREEN MANAGEMENT
// ===========================
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ===========================
// INIT
// ===========================
renderHistory();
</script>
</body>
</html>
